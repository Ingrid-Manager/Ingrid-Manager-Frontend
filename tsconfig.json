{
  "compilerOptions": {
    "target": "ESNext",

    "module": "ESNext",

    "strict": true,

    "moduleResolution": "Bundler",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["vite/client"],

    "jsx": "preserve",

    "isolatedModules": true,

    "skipLibCheck": true,

    "allowJs": false,

    "noEmit": true
  },

  "include": ["src/**/*.ts", "src/**/*.vue"]
}
